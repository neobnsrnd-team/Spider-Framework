              },
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"cards\": [\n    {\n      \"id\": \"1234567890123456\",\n      \"name\": \"HNC 플래티넘 카드\",\n      \"maskedNumber\": \"1234-****-****-3456\",\n      \"balance\": 500000,\n      \"paymentBank\": \"HNC은행\",\n      \"paymentAccount\": \"123-456-789012\"\n    }\n  ]\n}"
            }
          ]
        },
        {
          "name": "즉시결제 가능금액 조회",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/cards/:cardId/payable-amount",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cards", ":cardId", "payable-amount"],
              "variable": [
                {
                  "key": "cardId",
                  "value": "1234567890123456",
                  "description": "카드번호"
                }
              ]
            },
            "description": "해당 카드의 즉시결제 가능금액과 신용한도를 반환한다.\n\n응답: { payableAmount, creditLimit }"
          },
          "response": [
            {
              "name": "가능금액 조회 성공",
              "status": "OK",
              "code": 200,
              "originalRequest": {
                "method": "GET",
                "url": { "raw": "{{baseUrl}}/api/cards/1234567890123456/payable-amount" }
              },
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"payableAmount\": 300000,\n  \"creditLimit\": 1000000\n}"
            }
          ]
        },
        {
          "name": "즉시결제 처리",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pin\": \"123456\",\n  \"amount\": 50000,\n  \"accountNumber\": \"123-456-789012\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/cards/:cardId/immediate-pay",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cards", ":cardId", "immediate-pay"],
              "variable": [
                {
                  "key": "cardId",
                  "value": "1234567890123456",
                  "description": "카드번호"
                }
              ]
            },
            "description": "PIN 인증 후 즉시결제를 수행한다.\nPIN 오류 시 HTTP 403과 남은 시도 횟수(attemptsLeft)를 반환한다.\n\n요청: { pin, amount, accountNumber }\n응답: { paidAmount, processedCount, completedAt }"
          },
          "response": [
            {
              "name": "결제 성공",
              "status": "OK",
              "code": 200,
              "originalRequest": {
                "method": "POST",
                "url": { "raw": "{{baseUrl}}/api/cards/1234567890123456/immediate-pay" },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"pin\": \"123456\",\n  \"amount\": 50000,\n  \"accountNumber\": \"123-456-789012\"\n}"
                }
              },
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"paidAmount\": 50000,\n  \"processedCount\": 1,\n  \"completedAt\": \"2026-04-22T09:30:00\"\n}"
            },
            {
              "name": "PIN 오류",
              "status": "Forbidden",
              "code": 403,
              "originalRequest": {
                "method": "POST",
                "url": { "raw": "{{baseUrl}}/api/cards/1234567890123456/immediate-pay" },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"pin\": \"000000\",\n  \"amount\": 50000,\n  \"accountNumber\": \"123-456-789012\"\n}"
                }
              },
