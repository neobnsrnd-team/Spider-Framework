            },
            {
              "name": "잔액 부족",
              "status": "Bad Request",
              "code": 400,
              "originalRequest": {
                "method": "POST",
                "url": { "raw": "{{baseUrl}}/api/cards/1234567890123456/immediate-pay" },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"pin\": \"123456\",\n  \"amount\": 9999999,\n  \"accountNumber\": \"123-456-789012\"\n}"
                }
