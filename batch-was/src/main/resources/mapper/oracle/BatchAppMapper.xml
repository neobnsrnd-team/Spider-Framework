<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.batchwas.domain.batch.mapper.BatchAppMapper">

    <!-- batchAppId로 BATCH_APP_FILE_NAME 조회 (= Spring Batch Job Bean 이름) -->
    <select id="selectBatchAppFileName" resultType="String">
        SELECT BATCH_APP_FILE_NAME
        FROM FWK_BATCH_APP
        WHERE BATCH_APP_ID = #{batchAppId}
    </select>

</mapper>
